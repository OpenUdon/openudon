  "info": {
    "description": "Advisory OpenAPI overlay derived from official OpenWeatherMap Current Weather, One Call 3.0, and Geocoding API human documentation. This is not an official OpenWeatherMap OpenAPI document.",
    "title": "OpenWeatherMap Weather and Geocoding Advisory Overlay",
    "version": "2026-05-18"
  },
  "openapi": "3.0.3",
  "paths": {
    "/data/2.5/weather": {
      "get": {
        "description": "Advisory operation derived from official OpenWeatherMap Current Weather Data documentation.",
        "operationId": "getOpenWeatherMapCurrentWeather",
        "parameters": [
          {
            "description": "Latitude in decimal degrees.",
            "in": "query",
            "name": "lat",
            "required": true,
            "schema": {
              "maximum": 90,
              "minimum": -90,
              "type": "number"
            }
          },
          {
            "description": "Longitude in decimal degrees.",
            "in": "query",
            "name": "lon",
            "required": true,
            "schema": {
              "maximum": 180,
              "minimum": -180,
              "type": "number"
            }
          },
          {
            "description": "OpenWeather API key.",
            "in": "query",
            "name": "appid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Units of measurement.",
            "in": "query",
            "name": "units",
            "required": false,
            "schema": {
              "enum": [
                "standard",
                "metric",
                "imperial"
              ],
              "type": "string"
            }
          },
          {
            "description": "Language code.",
            "in": "query",
            "name": "lang",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentWeatherResponse"
                }
              }
            },
            "description": "Current weather response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenWeatherError"
                }
              }
            },
            "description": "OpenWeather error response."
          }
        },
        "security": [
          {
            "openWeatherAPIKey": []
          }
        ],
        "summary": "Get current weather data"
      }
    },
    "/data/3.0/onecall": {
      "get": {
        "description": "Advisory operation derived from official OpenWeatherMap One Call API 3.0 documentation.",
        "operationId": "getOpenWeatherMapOneCall3",
        "parameters": [
          {
            "description": "Latitude in decimal degrees, from -90 to 90. OpenWeatherMap directs callers that need to convert city names or zip codes to coordinates, or coordinates back to location names, to the Geocoding API.",
            "in": "query",
            "name": "lat",
            "required": true,
            "schema": {
              "maximum": 90,
              "minimum": -90,
              "type": "number"
            }
          },
          {
            "description": "Longitude in decimal degrees, from -180 to 180. OpenWeatherMap directs callers that need to convert city names or zip codes to coordinates, or coordinates back to location names, to the Geocoding API.",
            "in": "query",
            "name": "lon",
            "required": true,
            "schema": {
              "maximum": 180,
              "minimum": -180,
              "type": "number"
            }
          },
          {
            "description": "OpenWeather API key.",
            "in": "query",
            "name": "appid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Comma-separated weather data blocks to exclude, such as current,minutely,hourly,daily,alerts.",
            "in": "query",
            "name": "exclude",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Units of measurement.",
            "in": "query",
            "name": "units",
            "required": false,
            "schema": {
              "enum": [
                "standard",
                "metric",
                "imperial"
              ],
              "type": "string"
            }
          },
          {
            "description": "Language code.",
            "in": "query",
            "name": "lang",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OneCallResponse"
                }
              }
            },
            "description": "One Call API 3.0 response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenWeatherError"
                }
              }
            },
            "description": "OpenWeather error response."
          }
        },
        "security": [
          {
            "openWeatherAPIKey": []
          }
        ],
        "summary": "Get One Call API 3.0 weather data"
      }
    },
    "/geo/1.0/direct": {
      "get": {
        "description": "Advisory operation derived from official OpenWeatherMap Geocoding API documentation. Direct geocoding converts a city or area name to geographical coordinates.",
        "operationId": "geocodeOpenWeatherMapLocationName",
        "parameters": [
          {
            "description": "City name, optional US state code, and optional country code separated by commas. Use ISO 3166 country codes.",
            "in": "query",
            "name": "q",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "OpenWeather API key.",
            "in": "query",
            "name": "appid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Maximum number of matching locations to return, up to 5.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "maximum": 5,
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GeocodingLocation"
                  },
                  "type": "array"
                }
              }
            },
            "description": "List of matching geocoding locations."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenWeatherError"
                }
              }
            },
            "description": "OpenWeather error response."
          }
        },
        "security": [
          {
            "openWeatherAPIKey": []
          }
        ],
        "summary": "Geocode location name"
      }
    },
    "/geo/1.0/reverse": {
      "get": {
        "description": "Advisory operation derived from official OpenWeatherMap Geocoding API documentation. Reverse geocoding converts geographical coordinates to nearby location names.",
        "operationId": "reverseGeocodeOpenWeatherMapCoordinates",
        "parameters": [
          {
            "description": "Geographical coordinates: latitude.",
            "in": "query",
            "name": "lat",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "description": "Geographical coordinates: longitude.",
            "in": "query",
            "name": "lon",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "description": "OpenWeather API key.",
            "in": "query",
            "name": "appid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Maximum number of location names to return.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GeocodingLocation"
                  },
                  "type": "array"
                }
              }
            },
            "description": "List of nearby geocoding locations."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenWeatherError"
                }
              }
            },
            "description": "OpenWeather error response."
          }
        },
        "security": [
          {
            "openWeatherAPIKey": []
          }
        ],
        "summary": "Reverse geocode coordinates"
      }
    },
    "/geo/1.0/zip": {
      "get": {
        "description": "Advisory operation derived from official OpenWeatherMap Geocoding API documentation. Zip geocoding converts a zip/post code and country code to geographical coordinates.",
        "operationId": "geocodeOpenWeatherMapZipCode",
        "parameters": [
          {
            "description": "Zip/post code and country code separated by a comma. Use ISO 3166 country codes.",
            "in": "query",
            "name": "zip",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "OpenWeather API key.",
            "in": "query",
            "name": "appid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZipGeocodingResponse"
                }
              }
            },
            "description": "Zip or post-code geocoding result."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenWeatherError"
                }
              }
            },
            "description": "OpenWeather error response."
          }
        },
        "security": [
          {
            "openWeatherAPIKey": []
          }
        ],
        "summary": "Geocode zip or post code"
      }
    }
  },
  "security": [
    {
      "openWeatherAPIKey": []
    }
  ],
  "servers": [
    {
      "url": "https://api.openweathermap.org"
    }
  ],
  "x-apitools-overlay": {
    "derived_from_docs": true,
    "official_openapi": false,
    "overlay_id": "openweathermap-one-call-3-advisory-overlay",
    "provider_id": "openweathermap",
    "source_note": "OpenWeatherMap publishes human documentation for Current Weather, One Call API 3.0, Geocoding API coordinate lookup helpers, and API key usage, but no official OpenAPI document is recorded in the apitools catalog.",
    "source_refs": [
