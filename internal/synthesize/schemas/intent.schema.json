{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen.local/schemas/intent.schema.json",
  "title": "Ramen rollout intent",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow", "steps"],
  "properties": {
    "openapi": { "type": "string" },
    "server_url": { "type": "string" },
    "workflow": { "$ref": "#/$defs/workflow" },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/input" }
    },
    "triggers": {
      "type": "array",
      "items": { "$ref": "#/$defs/trigger" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "security": {
      "type": "array",
      "items": { "$ref": "#/$defs/security" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/output" }
    },
    "locals": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "$defs": {
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "sensitive": { "type": "boolean" },
        "default": { "type": "string" }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["http", "openapi", "fnct", "cmd", "ssh", "sequence", "parallel", "switch", "merge", "loop", "await"]
        },
        "do": { "type": "string", "minLength": 1 },
        "using": { "type": "string" },
        "set": { "type": "string" },
        "when": { "type": "string" },
        "for_each": { "type": "string" },
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "with": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "provider": { "type": "string" },
        "openapi": { "type": "string" },
        "operation": { "type": "string" },
        "bind": {
          "type": "array",
          "items": { "$ref": "#/$defs/bind" }
        },
        "items": { "type": "string" },
        "mode": { "type": "string" },
        "batch_size": { "type": "string" },
        "successCriteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/criterion" }
        },
        "onFailure": {
          "type": "array",
          "items": { "$ref": "#/$defs/failure_action" }
        },
        "onSuccess": {
          "type": "array",
          "items": { "$ref": "#/$defs/success_action" }
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" }
        },
        "cases": {
          "type": "array",
          "items": { "$ref": "#/$defs/case" }
        },
        "default": { "$ref": "#/$defs/default" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "openapi" } },
            "required": ["type"]
          },
          "then": { "required": ["operation"] }
        }
      ]
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition"],
      "properties": {
        "condition": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["simple", "regex", "jsonpath", "xpath"]
        },
        "context": { "type": "string" }
      }
    },
    "failure_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["end", "goto", "retry"]
        },
        "workflowId": { "type": "string" },
        "stepId": { "type": "string" },
        "retryAfter": { "type": "number", "minimum": 0 },
        "retryLimit": { "type": "integer", "minimum": 1 },
        "criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/criterion" }
        }
      }
    },
    "success_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["end", "goto"]
        },
        "workflowId": { "type": "string" },
        "stepId": { "type": "string" },
        "criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/criterion" }
        }
      }
    },
    "bind": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "when"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "when": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" }
        }
      }
    },
    "default": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" }
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "authentication": { "type": "string" },
        "methods": {
          "type": "array",
          "items": { "type": "string" }
        },
        "routes": {
          "type": "array",
          "items": { "$ref": "#/$defs/trigger_route" }
        },
        "options": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "trigger_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output"],
      "properties": {
        "output": { "type": "string", "minLength": 1 },
        "to": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "token_from": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "from"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "from": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    }
  }
}
